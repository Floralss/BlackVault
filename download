<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,viewport-fit=cover"/>
<title>BlackVault</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='24' fill='%235B4FE9'/><text y='.85em' font-size='60' x='20'>🔐</text></svg>"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="style.css"/>
</head>
<body>


<div id="loader"><div class="ld-logo">🔐</div><div class="ld-name">BlackVault</div><div class="ld-dots"><i></i><i></i><i></i></div></div>

<div id="pinWall">
  <div class="pin-ico">🔐</div><div class="pin-h">BlackVault</div><div class="pin-s">Введите PIN-код</div>
  <div class="pin-track"><div class="pin-d" id="pd0"></div><div class="pin-d" id="pd1"></div><div class="pin-d" id="pd2"></div><div class="pin-d" id="pd3"></div></div>
  <div class="pin-grid">
    <div class="pin-k" data-v="1">1</div><div class="pin-k" data-v="2">2</div><div class="pin-k" data-v="3">3</div>
    <div class="pin-k" data-v="4">4</div><div class="pin-k" data-v="5">5</div><div class="pin-k" data-v="6">6</div>
    <div class="pin-k" data-v="7">7</div><div class="pin-k" data-v="8">8</div><div class="pin-k" data-v="9">9</div>
    <div class="pin-k sub"></div><div class="pin-k" data-v="0">0</div><div class="pin-k sub" data-v="del">⌫</div>
  </div>
  <div id="pinErr"></div>
</div>

<div id="toastRoot"></div>

<!-- UPDATE LOG -->
<div id="updateLogOverlay">
  <div class="update-log-card">
    <div class="update-log-icon">🚀</div>
    <div class="update-log-title">BlackVault обновлён!</div>
    <div class="update-log-sub">Версия 6.0 — что нового:</div>
    <div class="update-log-list" id="updateLogList"></div>
    <button class="btn btn-primary" id="btnCloseUpdateLog">Понятно, спасибо!</button>
  </div>
</div>

<div id="authScreen" style="display:none">
  <div id="pgLogin" class="auth-screen">
    <div class="auth-card">
      <div class="auth-logo"><div class="auth-logo-ico">🔐</div><span class="auth-logo-name">BlackVault</span></div>
      <div class="auth-title">Добро пожаловать</div><div class="auth-sub">Войдите в свой кошелёк</div>
      <div class="form-group"><label class="form-label">Email</label><input id="lEmail" class="form-input" type="email" placeholder="you@example.com"/></div>
      <div class="form-group"><label class="form-label">Пароль</label><input id="lPass" class="form-input" type="password" placeholder="••••••••"/></div>
      <button class="btn btn-primary" id="btnLogin">Войти</button>
      <div class="divider">или</div>
      <button class="btn btn-google" id="btnGoo1"><img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="16"/> Google</button>
      <div class="auth-foot">Нет аккаунта? <a id="toReg">Регистрация</a></div>
    </div>
  </div>
  <div id="pgReg" class="auth-screen" style="display:none">
    <div class="auth-card">
      <div class="auth-logo"><div class="auth-logo-ico">🔐</div><span class="auth-logo-name">BlackVault</span></div>
      <div class="auth-title">Создать аккаунт</div><div class="auth-sub">Присоединяйтесь к BlackVault</div>
      <div class="form-group"><label class="form-label">Email</label><input id="rEmail" class="form-input" type="email" placeholder="you@example.com"/></div>
      <div class="form-group"><label class="form-label">Пароль</label><input id="rPass" class="form-input" type="password" placeholder="Минимум 6 символов"/></div>
      <div class="form-group"><label class="form-label">Повтор пароля</label><input id="rPass2" class="form-input" type="password" placeholder="••••••••"/></div>
      <button class="btn btn-primary" id="btnReg">Создать аккаунт</button>
      <div class="divider">или</div>
      <button class="btn btn-google" id="btnGoo2"><img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="16"/> Google</button>
      <div class="auth-foot">Уже есть аккаунт? <a id="toLg">Войти</a></div>
    </div>
  </div>
  <div id="pgUname" class="auth-screen" style="display:none">
    <div class="auth-card">
      <div class="auth-logo"><div class="auth-logo-ico">🔐</div><span class="auth-logo-name">BlackVault</span></div>
      <div class="auth-title">Ваш никнейм</div><div class="auth-sub">Выберите уникальное имя</div>
      <div class="form-group"><label class="form-label">Никнейм</label><input id="unameI" class="form-input" maxlength="24" placeholder="CryptoKing"/></div>
      <button class="btn btn-primary" id="btnUname">Продолжить →</button>
    </div>
  </div>
</div>

<div id="app" style="display:none">
  <button id="mobMenuBtn">☰</button>
  <div id="sbOverlay"></div>

  <div id="sidebar">
    <div class="sb-header"><div class="sb-brand"><div class="sb-brand-ico">🔐</div><div class="sb-brand-name">BlackVault</div></div></div>
    <div class="sb-user" data-goto="pgWallet">
      <div class="sb-av" id="sbAv"><span id="sbAvT">?</span><img id="sbAvI"/></div>
      <div style="flex:1;min-width:0"><div class="sb-uname" id="sbName">—</div><div class="sb-code" id="sbCode">BV-??????</div></div>
      <div id="sbRoleBadge"></div>
    </div>

    <div class="sb-nav">
      <div class="sb-sep">Кошелёк</div>
      <div class="sb-grid">
        <div class="sb-tile on" data-goto="pgWallet"><span class="ic">💳</span><span class="lb">Главная</span></div>
        <div class="sb-tile" data-goto="pgAssets"><span class="ic">💎</span><span class="lb">Активы</span></div>
        <div class="sb-tile" data-goto="pgTransfer"><span class="ic">↗️</span><span class="lb">Перевод</span></div>
        <div class="sb-tile" data-goto="pgExchange"><span class="ic">💱</span><span class="lb">Обмен</span></div>
        <div class="sb-tile" data-goto="pgStocks"><span class="ic">📈</span><span class="lb">Акции</span></div>
        <div class="sb-tile" data-goto="pgDeposit"><span class="ic">📥</span><span class="lb">Пополнить</span><span class="dot" id="depDot"></span></div>
        <div class="sb-tile" data-goto="pgChecks"><span class="ic">🧾</span><span class="lb">Чеки</span></div>
        <div class="sb-tile" data-goto="pgContests"><span class="ic">🎉</span><span class="lb">Конкурсы</span></div>
      </div>

      <div class="sb-sep">Сообщество</div>
      <div class="sb-list-item" data-goto="pgHistory"><span class="ic">📋</span>История</div>
      <div class="sb-list-item" data-goto="pgLeaderboard"><span class="ic">🏆</span>Forbes</div>
      <div class="sb-list-item" data-goto="pgShop"><span class="ic">🛍</span>Магазин</div>
      <div class="sb-list-item" data-goto="pgSupport"><span class="ic">🎧</span>Поддержка<span class="sb-badge" id="sbSupportBadge" style="display:none">!</span></div>

      <div id="sbAdminGroup" style="display:none">
        <div class="sb-sep">Управление</div>
        <div class="sb-list-item" data-goto="pgAdmin"><span class="ic">👑</span>Панель<span class="sb-badge" id="sbAdminBadge" style="display:none">!</span></div>
      </div>
    </div>

    <div class="sb-footer">
      <div class="sb-list-item" data-goto="pgSettings"><span class="ic">⚙️</span>Настройки</div>
      <div class="sb-logout" id="btnLogout">⬅️ Выйти</div>
    </div>
  </div>

  <div id="main">

    <div class="page on" id="pgWallet">
      <div class="ph"><div class="ph-top"><div><div class="ph-title" id="homeGreet">Кошелёк</div><div class="ph-sub" id="homeDate"></div></div><div id="homeBadge"></div></div></div>
      <div id="homeBlockedBanner" style="display:none;background:rgba(255,77,106,.12);border:1px solid rgba(255,77,106,.25);border-radius:var(--rs);padding:13px 17px;margin-bottom:17px;font-size:13px;color:#FF8FA3;font-weight:600">🔒 Кошелёк заблокирован. <span style="text-decoration:underline;cursor:pointer" data-goto="pgSupport">Поддержка</span></div>
      <div class="wallet-hero">
        <div class="wh-label">Общий баланс</div>
        <div class="wh-amount"><span>$</span><span id="wBalInt">0</span><span id="wBalDec" style="opacity:.6">.00</span></div>
        <div class="wh-sub" id="wSub">Кошелёк BlackVault</div>
        <div class="wh-code" id="wCode" onclick="copyCode()">🔑 <span id="wCodeTxt">BV-??????</span> <span style="opacity:.5">⎘</span></div>
        <div class="wh-actions">
          <div class="wh-btn" data-goto="pgDeposit"><span class="wh-btn-icon">📥</span>Пополнить</div>
          <div class="wh-btn primary" data-goto="pgTransfer"><span class="wh-btn-icon">↗️</span>Перевод</div>
          <div class="wh-btn dis" onclick="toast('Вывод временно недоступен','w')"><span class="wh-btn-icon">📤</span>Вывести</div>
          <div class="wh-btn" data-goto="pgExchange"><span class="wh-btn-icon">💱</span>Обмен</div>
          <div class="wh-btn" data-goto="pgChecks"><span class="wh-btn-icon">🧾</span>Чек</div>
        </div>
      </div>
      <div class="sec"><div class="sec-head"><span class="sec-title">Активы</span><span class="sec-link" data-goto="pgAssets">Все</span></div><div class="asset-list" id="homeAssets"></div></div>
      <div class="sec"><div class="sec-head"><span class="sec-title">Последние операции</span><span class="sec-link" data-goto="pgHistory">Все</span></div><div id="homeTx"><div class="empty-state"><span class="emo">📭</span>Операций пока нет</div></div></div>
    </div>

    <div class="page" id="pgAssets">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">💎 Активы</div><div class="ph-sub">Ваш крипто-портфель</div></div></div></div>
      <div class="sec"><div class="asset-list" id="assetsList"></div></div>
    </div>

    <div class="page" id="pgTransfer">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">↗️ Перевод</div><div class="ph-sub">Отправить средства</div></div></div></div>
      <div class="sec card-p" style="max-width:480px">
        <div class="form-group"><label class="form-label">Получатель</label><input class="form-input" id="trTo" placeholder="BV-XXXXXX или @nickname"/></div>
        <div class="form-group"><label class="form-label">Валюта и сумма</label>
          <div class="input-row">
            <select class="form-input" id="trCur"><option value="USD">💵 USD</option><option value="UAH">🇺🇦 UAH</option><option value="RUB">🇷🇺 RUB</option><option value="TON">💎 TON</option><option value="BTC">₿ BTC</option><option value="ETH">⟠ ETH</option></select>
            <input class="form-input" id="trAmt" type="number" placeholder="0.00"/>
          </div>
          <div class="form-hint" id="trBalHint">Доступно: —</div>
        </div>
        <div class="form-group"><label class="form-label">Комментарий</label><input class="form-input" id="trComment" placeholder="Необязательно..."/></div>
        <div style="background:var(--c-surface2);border-radius:var(--rs);padding:13px 15px;font-size:13px;color:var(--c-text2);margin-bottom:15px">⏳ Обработка ~5 секунд. Комиссия 0%</div>
        <button class="btn btn-primary" id="btnTransfer">Отправить</button>
        <div class="pending-box" id="trPending"><div style="font-size:13px;color:#D4C5FF;font-weight:700">⏳ Выполняем перевод...</div><div class="progress-bar"><div class="progress-fill" id="trBar" style="width:0%"></div></div></div>
      </div>
    </div>

    <div class="page" id="pgExchange">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">💱 Обмен</div><div class="ph-sub">По рыночному курсу</div></div></div></div>
      <div style="max-width:480px">
        <div class="ex-wrap">
          <div class="ex-side"><div class="ex-label">Отдаёте</div>
            <div class="input-row"><select class="form-input" id="exFrom"><option value="USD">💵 USD</option><option value="UAH">🇺🇦 UAH</option><option value="RUB">🇷🇺 RUB</option><option value="TON">💎 TON</option><option value="BTC">₿ BTC</option><option value="ETH">⟠ ETH</option></select><input class="form-input" id="exAmt" type="number" placeholder="0.00"/></div>
          </div>
          <div class="ex-mid"><div class="ex-swap-btn" id="btnSwapEx">⇅</div></div>
          <div class="ex-side" style="border-bottom:none"><div class="ex-label">Получаете</div>
            <div class="input-row"><select class="form-input" id="exTo"><option value="TON">💎 TON</option><option value="BTC">₿ BTC</option><option value="ETH">⟠ ETH</option><option value="USD">💵 USD</option><option value="UAH">🇺🇦 UAH</option><option value="RUB">🇷🇺 RUB</option></select><input class="form-input" id="exOut" readonly placeholder="~0.00" style="opacity:.75"/></div>
          </div>
        </div>
        <div id="exRateInfo" style="font-size:13px;color:var(--c-text2);padding:11px 4px;font-weight:500">Выберите валюты и сумму</div>
        <div style="background:var(--c-surface);border-radius:var(--rs);padding:13px 15px;font-size:13px;color:var(--c-text2);margin-bottom:15px;border:1px solid var(--c-border)">⏳ Время обмена: ~1 минута</div>
        <button class="btn btn-primary" id="btnExchange">Обменять</button>
        <div class="pending-box" id="exPending"><div style="font-size:13px;color:#D4C5FF;font-weight:700">💱 Выполняем обмен...</div><div class="progress-bar"><div class="progress-fill" id="exBar" style="width:0%"></div></div></div>
      </div>
    </div>

    <!-- STOCKS -->
    <div class="page" id="pgStocks">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">📈 Акции</div><div class="ph-sub">Покупайте акции по реальным ценам</div></div></div></div>
      <div class="sec"><div id="stocksList" class="asset-list"></div></div>
      <div class="sec"><div class="sec-head"><span class="sec-title">Мои акции</span></div><div id="myStocksList"><div class="empty-state"><span class="emo">📈</span>У вас пока нет акций</div></div></div>
    </div>

    <div class="page" id="pgDeposit">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">📥 Пополнение</div><div class="ph-sub">Заявка обрабатывается администратором</div></div>
      <button class="btn btn-primary btn-sm" id="btnNewDeposit">+ Новая заявка</button></div></div>
      <div class="sec" id="depRequestsWrap"><div class="empty-state"><span class="emo">📥</span>Нет заявок</div></div>
    </div>

    <div class="page" id="pgChecks">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">🧾 Чеки</div><div class="ph-sub">Создавайте и принимайте платежи</div></div>
      <button class="btn btn-primary btn-sm" id="btnOpenCheck">+ Создать</button></div></div>
      <div style="display:flex;gap:8px;margin-bottom:17px">
        <button class="btn btn-primary btn-sm" id="chkTabMy" onclick="chkTab('my')">Мои чеки</button>
        <button class="btn btn-secondary btn-sm" id="chkTabPay" onclick="chkTab('pay')">Оплатить</button>
      </div>
      <div id="myChecksWrap"><div id="myChecksList"><div class="empty-state"><span class="emo">🧾</span>Чеков нет</div></div></div>
      <div id="payCheckWrap" style="display:none">
        <div class="sec card-p" style="max-width:480px">
          <div class="form-group"><label class="form-label">ID чека</label><div style="display:flex;gap:8px"><input class="form-input" id="payChkId" placeholder="Введите ID"/><button class="btn btn-primary btn-sm" id="btnPayChk" style="white-space:nowrap">Оплатить</button></div></div>
        </div>
      </div>
    </div>

    <!-- CONTESTS -->
    <div class="page" id="pgContests">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">🎉 Конкурсы</div><div class="ph-sub">Участвуйте и выигрывайте призы</div></div></div></div>
      <div id="contestsList"><div class="empty-state"><span class="emo">🎉</span>Активных конкурсов нет</div></div>
    </div>

    <div class="page" id="pgHistory">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">📋 История</div><div class="ph-sub">Все операции</div></div></div></div>
      <div class="sec" id="histWrap"><div class="empty-state"><span class="emo">📭</span>Нет операций</div></div>
    </div>

    <div class="page" id="pgLeaderboard">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">🏆 Forbes</div><div class="ph-sub">Рейтинг богатейших</div></div></div></div>
      <div class="sec" id="lbWrap"><div class="empty-state"><span class="emo">⏳</span>Загрузка...</div></div>
    </div>

    <div class="page" id="pgShop">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">🛍 Магазин</div><div class="ph-sub">Кастомизация, привилегии и интерфейсы</div></div></div></div>

      <div class="shop-item">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <div style="font-size:16px;font-weight:800">⭐ Уникальный тег</div>
          <span class="price-tag">от 150 ₴</span>
        </div>
        <div style="font-size:13px;color:var(--c-text2);margin-bottom:6px">Своё название, цвет, палитра, шрифт. Можно иметь несколько тегов одновременно!</div>
        <div id="myTagsInfo" class="tag-row" style="margin:8px 0"></div>
        <button class="btn btn-gold btn-sm" onclick="openSheet('sheetCreateTag')" id="btnShowCreateTag">Создать тег</button>
      </div>

      <div class="shop-item">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <div style="font-size:16px;font-weight:800">🎨 Кастомизация служебного тега</div>
          <span class="price-tag">от 200 ₴</span>
        </div>
        <div style="font-size:13px;color:var(--c-text2);margin-bottom:10px">Только для Admin/Helper/Owner — измените цвет и эффект тега (название менять нельзя)</div>
        <button class="btn btn-gold btn-sm" onclick="openSheet('sheetCustomizeTag')">Кастомизировать</button>
      </div>

      <div class="shop-item">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <div style="font-size:16px;font-weight:800">🖌 Кастомизация интерфейса</div>
          <span class="price-tag">от 50 ₴</span>
        </div>
        <div style="font-size:13px;color:var(--c-text2);margin-bottom:10px">Цвета кнопок, своя картинка на фон кнопок. Тему можно передать другу по коду!</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button class="btn btn-gold btn-sm" onclick="openSheet('sheetCustomizeUI')">Купить кастомизацию</button>
          <button class="btn btn-secondary btn-sm" onclick="openSheet('sheetUseTheme')">Код темы</button>
        </div>
      </div>

      <div class="shop-item">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <div style="font-size:16px;font-weight:800">🖼 Рамка аватара</div>
          <span class="price-tag">от 80 ₴</span>
        </div>
        <div style="font-size:13px;color:var(--c-text2);margin-bottom:10px">Цветная светящаяся рамка вокруг аватара</div>
        <button class="btn btn-gold btn-sm" onclick="openSheet('sheetAvatarFrame')">Выбрать рамку</button>
      </div>

      <div class="shop-item">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <div style="font-size:16px;font-weight:800">⭐ VIP статус в Forbes</div>
          <span class="price-tag">от 150 ₴</span>
        </div>
        <div style="font-size:13px;color:var(--c-text2);margin-bottom:10px">Звёздочка ⭐ рядом с именем в рейтинге на 30 дней</div>
        <button class="btn btn-gold btn-sm" onclick="openSheet('sheetVip')">Купить VIP</button>
      </div>
    </div>

    <div class="page" id="pgSupport">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">🎧 Поддержка</div><div class="ph-sub">Обращения и тикеты</div></div>
      <button class="btn btn-primary btn-sm" id="btnNewReport">+ Обращение</button></div></div>
      <div class="sec" id="reportsWrap"><div class="empty-state"><span class="emo">🎧</span>Нет обращений</div></div>
    </div>

    <div class="page" id="pgAdmin">
      <div class="ph"><div class="ph-top"><div><div class="ph-title">👑 Панель</div><div class="ph-sub" id="adminRoleSub">Управление</div></div><div id="adminTopBadge"></div></div></div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:19px" id="adminTabs">
        <button class="btn btn-primary btn-sm" onclick="admTab('wallets')">Кошельки</button>
        <button class="btn btn-secondary btn-sm" onclick="admTab('deposits')">Пополнения<span id="admDepCount" style="margin-left:5px"></span></button>
        <button class="btn btn-secondary btn-sm" onclick="admTab('tx')">Транзакции</button>
        <button class="btn btn-secondary btn-sm" onclick="admTab('reports')">Тикеты</button>
        <button class="btn btn-secondary btn-sm" onclick="admTab('tgreq')">TG/DC</button>
        <button class="btn btn-secondary btn-sm" id="admGiveTabBtn" style="display:none" onclick="admTab('give')">Выдать</button>
