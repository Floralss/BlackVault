    <div class="form-group"><label class="form-label">Эффект</label><select class="form-input" id="ctEffect"><option value="solid">Обычный фон</option><option value="rainbow">🌈 Переливание цветов</option></select></div>
    <div class="form-group"><label class="form-label">Превью</label><div style="background:var(--c-surface2);border-radius:var(--rs);padding:16px;text-align:center"><span id="ctPreview" class="role-tag" style="background:#7C5CFC22;border-color:#7C5CFC55;color:#7C5CFC">PREVIEW</span></div></div>
    <div class="form-group"><label class="form-label">Способ оплаты (150 ₴ или эквивалент)</label><div class="curr-pay-row" id="ctPayRow"></div></div>
    <button class="btn btn-gold" id="btnBuyTag" style="margin-top:6px">Купить тег</button>
  </div></div>
</div>

<div class="overlay" id="sheetCustomizeTag"><div class="sheet"><div class="sheet-handle"></div>
  <div class="sheet-head"><div class="sheet-title">🎨 Кастомизация служебного тега</div><button class="sheet-close" onclick="closeSheet('sheetCustomizeTag')">✕</button></div>
  <div class="sheet-body">
    <div id="custTagNotice" style="background:rgba(124,92,252,.1);border:1px solid rgba(124,92,252,.22);border-radius:var(--rs);padding:13px 15px;margin-bottom:15px;font-size:13px;color:#D4C5FF"></div>
    <div class="form-group"><label class="form-label">Цвет тега</label><div class="swatches" id="custColors"></div></div>
    <div class="form-group" id="custEffectGroup"><label class="form-label">Эффект</label>
      <select class="form-input" id="custEffect"><option value="solid">Обычный</option><option value="rainbow">🌈 Переливание цветов</option><option value="redblack">🔴⚫ Красно-чёрный</option></select>
    </div>
    <div class="form-group"><label class="form-label">Способ оплаты (200 ₴ или эквивалент)</label><div class="curr-pay-row" id="custPayRow"></div></div>
    <button class="btn btn-gold" id="btnBuyCustomize" style="margin-top:6px">Применить</button>
  </div></div>
</div>

<!-- UI CUSTOMIZATION - FIXED with image upload -->
<div class="overlay" id="sheetCustomizeUI"><div class="sheet"><div class="sheet-handle"></div>
  <div class="sheet-head"><div class="sheet-title">🖌 Кастомизация интерфейса</div><button class="sheet-close" onclick="closeSheet('sheetCustomizeUI')">✕</button></div>
  <div class="sheet-body">
    <div style="display:flex;gap:8px;margin-bottom:17px">
      <button class="btn btn-primary btn-sm" id="uiModeColor" onclick="setUiMode('color')">🎨 Цвета</button>
      <button class="btn btn-secondary btn-sm" id="uiModeImage" onclick="setUiMode('image')">🖼 Картинка</button>
    </div>
    <div id="uiColorSection">
      <div class="form-group"><label class="form-label">Основной цвет кнопок</label><div class="swatches" id="uiColors1"></div></div>
      <div class="form-group"><label class="form-label">Цвет градиента</label><div class="swatches" id="uiColors2"></div></div>
    </div>
    <div id="uiImageSection" style="display:none">
      <div class="form-group"><label class="form-label">Изображение для фона кнопок</label>
        <label class="btn btn-secondary" style="display:inline-flex;cursor:pointer">📁 Выбрать картинку<input type="file" id="uiImgIn" accept="image/*" style="display:none"/></label>
      </div>
    </div>
    <div style="background:var(--c-surface2);border-radius:var(--rs);padding:15px;margin-bottom:15px;text-align:center">
      <div style="font-size:11px;color:var(--c-text3);margin-bottom:8px;font-weight:700;text-transform:uppercase">Превью кнопки</div>
      <button class="btn" id="uiPreviewBtn" style="background:linear-gradient(150deg,#A78BFA,#7C5CFC);color:#fff;width:auto;padding:12px 24px">Пример кнопки</button>
    </div>
    <div class="form-group"><label class="form-label">Способ оплаты (50 ₴ или эквивалент)</label><div class="curr-pay-row" id="uiPayRow"></div></div>
    <button class="btn btn-gold" id="btnBuyUI">Применить</button>
    <div id="myThemeCodeWrap" style="margin-top:17px;display:none">
      <div style="font-size:12px;font-weight:800;text-transform:uppercase;color:var(--c-text3);margin-bottom:9px">Ваш код темы (передайте другу)</div>
      <div style="display:flex;gap:8px"><input class="form-input" id="myThemeCode" readonly/><button class="btn btn-secondary btn-sm" onclick="copyThemeCode()">📋</button></div>
    </div>
  </div></div>
</div>

<div class="overlay" id="sheetUseTheme"><div class="sheet"><div class="sheet-handle"></div>
  <div class="sheet-head"><div class="sheet-title">🔑 Использовать код темы</div><button class="sheet-close" onclick="closeSheet('sheetUseTheme')">✕</button></div>
  <div class="sheet-body">
    <div class="form-group"><label class="form-label">Код темы от друга</label><input class="form-input" id="useThemeCodeIn" placeholder="BVTHEME-XXXXXX"/></div>
    <button class="btn btn-primary" id="btnUseTheme">Использовать</button>
  </div></div>
</div>

<div class="overlay" id="sheetAvatarFrame"><div class="sheet"><div class="sheet-handle"></div>
  <div class="sheet-head"><div class="sheet-title">🖼 Рамка аватара</div><button class="sheet-close" onclick="closeSheet('sheetAvatarFrame')">✕</button></div>
  <div class="sheet-body">
    <div class="form-group"><label class="form-label">Цвет рамки</label><div class="swatches" id="frameColors"></div></div>
    <div style="background:var(--c-surface2);border-radius:var(--rs);padding:15px;margin-bottom:15px;text-align:center">
      <div class="sb-av" id="framePreview" style="width:64px;height:64px;font-size:24px;margin:0 auto"><span id="framePreviewTxt">?</span><img id="framePreviewImg"/></div>
    </div>
    <div class="form-group"><label class="form-label">Способ оплаты (80 ₴ или эквивалент)</label><div class="curr-pay-row" id="framePayRow"></div></div>
    <button class="btn btn-gold" id="btnBuyFrame">Применить</button>
  </div></div>
</div>

<div class="overlay" id="sheetVip"><div class="sheet"><div class="sheet-handle"></div>
  <div class="sheet-head"><div class="sheet-title">⭐ VIP статус</div><button class="sheet-close" onclick="closeSheet('sheetVip')">✕</button></div>
  <div class="sheet-body">
    <div style="font-size:13px;color:var(--c-text2);margin-bottom:15px">Звёздочка ⭐ рядом с вашим именем в рейтинге Forbes на 30 дней</div>
    <div class="form-group"><label class="form-label">Способ оплаты (150 ₴ или эквивалент)</label><div class="curr-pay-row" id="vipPayRow"></div></div>
    <button class="btn btn-gold" id="btnBuyVip">Купить VIP на 30 дней</button>
  </div></div>
</div>

<!-- STOCK BUY -->
<div class="overlay" id="sheetBuyStock"><div class="sheet"><div class="sheet-handle"></div>
  <div class="sheet-head"><div class="sheet-title" id="stockSheetTitle">Купить акции</div><button class="sheet-close" onclick="closeSheet('sheetBuyStock')">✕</button></div>
  <div class="sheet-body">
    <div id="stockInfo" style="background:var(--c-surface2);border-radius:var(--rs);padding:15px;margin-bottom:15px"></div>
    <div class="form-group"><label class="form-label">Валюта оплаты</label><select class="form-input" id="stockPayCur"><option value="USD">USD</option><option value="UAH">UAH</option><option value="RUB">RUB</option><option value="TON">TON</option><option value="BTC">BTC</option><option value="ETH">ETH</option></select></div>
    <div class="form-group"><label class="form-label">Количество акций</label><input class="form-input" id="stockQty" type="number" placeholder="1" min="0.01" step="0.01"/></div>
    <div class="form-hint" id="stockCostHint">Стоимость: —</div>
    <button class="btn btn-primary" id="btnBuyStockConfirm" style="margin-top:14px">Купить</button>
  </div></div>
</div>

<!-- CONTEST PARTICIPATE -->
<div class="overlay" id="sheetContestDetail"><div class="sheet"><div class="sheet-handle"></div>
  <div class="sheet-head"><div class="sheet-title" id="contestDetailTitle">Конкурс</div><button class="sheet-close" onclick="closeSheet('sheetContestDetail')">✕</button></div>
  <div class="sheet-body" id="contestDetailBody"></div>
</div></div>


<script type="module" src="app.js"></script>
</body>
</html>
