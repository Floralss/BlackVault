rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isMe(uid) { return signedIn() && request.auth.uid == uid; }

    // Бутстрап-админ: постоянный доступ по email/UID, даже если в базе
    // ещё нет документа с ролью. Продублируйте здесь то же, что в
    // js/firebase-config.js (ADMIN_EMAILS / ADMIN_UIDS).
    function isBootstrapAdmin() {
      return signedIn() && (
        request.auth.token.email in ["strepoomich27@gmail.com"] ||
        request.auth.uid in []
      );
    }

    // Динамическая роль хранится в собственном документе пользователя —
    // её можно менять через Админ-панель без переразвёртывания правил.
    function myRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    function isAdmin()  { return isBootstrapAdmin() || myRole() == "admin"; }
    function isHelper() { return isAdmin() || myRole() == "helper"; }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isMe(uid);

      // Обычный пользователь может менять свои поля, КРОМЕ premium/role/banned —
      // это и есть защита от "накрутки" премиума или самоназначения себя админом.
      allow update: if isAdmin()
        || (isHelper() && !isMe(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["banned"]))
        || (isMe(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["premium","role","banned"]));

      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, update: if signedIn() && request.auth.uid in resource.data.members;
      allow create: if signedIn() && request.auth.uid in request.resource.data.members;

      match /messages/{msgId} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow update: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"]);
        allow delete: if false;
      }
    }

    match /channels/{id} { allow read: if signedIn(); allow write: if isAdmin(); }
    match /groups/{id}   { allow read: if signedIn(); allow write: if isAdmin(); }

    match /plans/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
