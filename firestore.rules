rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isMe(uid) { return signedIn() && request.auth.uid == uid; }
    // ⚠️ Продублируйте сюда те же UID, что в js/firebase-config.js (ADMIN_UIDS).
    // Лучше заменить на custom claims: request.auth.token.admin == true
    function isAdmin() {
      return signedIn() && request.auth.uid in [
        // "UID_АДМИНА_1"
      ];
    }

    match /users/{uid} {
      allow read: if signedIn();          // профиль читают все (приватность полей — на уровне приложения/Cloud Functions)
      allow create: if isMe(uid);
      allow update: if isMe(uid) && !("premium" in request.resource.data.diff(resource.data).affectedKeys());
      // поле "premium" нельзя менять напрямую из браузера — только через
      // Cloud Function после подтверждённой оплаты. Это ключевая защита
      // от "взлома", о которой просили в задании: деньги/права не должны
      // выставляться клиентским JS.
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read, update: if signedIn() && request.auth.uid in resource.data.members;
      allow create: if signedIn() && request.auth.uid in request.resource.data.members;

      match /messages/{msgId} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow update, delete: if false;
      }
    }

    match /channels/{id} { allow read: if signedIn(); allow write: if isAdmin(); }
    match /groups/{id}   { allow read: if signedIn(); allow write: if isAdmin(); }

    match /plans/{id} {
      allow read: if true;        // тарифы видны даже неавторизованным на лендинге
      allow write: if isAdmin();  // цены редактирует только админ — проверка на сервере, а не в интерфейсе
    }
  }
}
